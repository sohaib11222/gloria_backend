# Copy to .env and fill in values. Never commit .env or real keys.

# Stripe (billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Email — Brevo (https://www.brevo.com): when SMTP is blocked on the VPS, use the v3 API over HTTPS:
# Create key: https://app.brevo.com/settings/keys/api (value starts with xkeysib-). Authenticate domain/senders:
# https://app.brevo.com/senders/domain/list
# BREVO_API_KEY=
# Optional SMTP relay (requires outbound 587): smtp-relay.brevo.com:587, user *@smtp-brevo.com, pass xsmtpsib-…

# Email — when outbound SMTP (465/587) is blocked on the VPS, use HTTPS mail on port 443 instead:
# SendGrid: create API key, verify sender (e.g. info@gloriaconnect.com), then:
# SENDGRID_API_KEY=
# Or Resend:
# RESEND_API_KEY=
# Priority in app: SendGrid → Resend → Brevo → SMTP. API keys override admin + .env SMTP.

# Email — SMTP (works only if the server can reach the host: openssl s_client -connect HOST:PORT)
# Domain relay (GoDaddy-style): outgoing server = your domain, port 465, SSL. Quote EMAIL_PASS if it has # or comma.
EMAIL_HOST=gloriaconnect.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# Email — alternative: Microsoft SMTP (STARTTLS on 587)
# EMAIL_HOST=smtp.office365.com
# EMAIL_PORT=587
# EMAIL_SECURE=false

# Optional: socket timeouts in ms (default 45000)
# EMAIL_SMTP_TIMEOUT_MS=45000

# Optional: third-party OTP relay (JSON POST). Leave unset to use SMTP only.
# OTP_EMAIL_API_URL=
# Optional: include raw SMTP/API hints in API JSON (avoid in public production).
# EXPOSE_EMAIL_DELIVERY_DETAILS=false
