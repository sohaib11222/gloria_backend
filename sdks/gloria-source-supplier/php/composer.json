{
  "name": "gloria/client-supplier-adapter",
  "description": "PHP OTA XML adapter for Gloria client-side supplier integration",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": ">=8.1",
    "guzzlehttp/guzzle": "^7.8",
    "psr/log": "^3.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
      "Gloria\\Client\\Supplier\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Gloria\\Client\\Supplier\\Tests\\": "tests/"
    }
  }
}
